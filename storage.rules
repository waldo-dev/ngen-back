rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // APK de prueba para stakeholders (lectura publica; escritura solo autenticados)
    match /public-releases/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
