# Copiar a ".env" en esta carpeta (no commitear). Usado por dotenv en local.
# Sin espacios alrededor del =. No uses "GOOGLE_CREDENTIALS" aquí: no está referenciado en el código.
# Credenciales de Firebase Admin: variable de entorno GOOGLE_APPLICATION_CREDENTIALS (ruta al JSON), no esta clave.
# En producción: configura las mismas claves en Cloud Functions / Secret Manager.
GOOGLE_MAPS_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
